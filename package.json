{
  "name": "pokemon-hub-team-builder",
  "displayName": "Pokémon Hub - Team Builder & Pokédex",
  "description": "Professional Pokémon team builder with advanced analytics, Pokédex integration, and Pokémon Showdown compatibility. Features competitive team building tools, stat calculators, and comprehensive Pokémon data.",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "author": {
    "name": "Victor Williams",
    "email": "victor.williams.dev@gmail.com",
    "url": "https://github.com/Vaporjawn"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Vaporjawn/Pokemon-Showdown-Team-Builder.git"
  },
  "homepage": "https://vaporjawn.github.io/Pokemon-Showdown-Team-Builder",
  "bugs": {
    "url": "https://github.com/Vaporjawn/Pokemon-Showdown-Team-Builder/issues"
  },
  "keywords": [
    "pokemon",
    "team-builder",
    "pokedex",
    "showdown",
    "competitive",
    "react",
    "typescript",
    "vite",
    "material-ui",
    "gaming"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "build:analyze": "npm run build && npx vite-bundle-analyzer dist/stats.html",
    "preview": "vite preview --host",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "prepare": "husky install",
    "clean": "rimraf dist node_modules/.cache"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.6",
    "@mui/icons-material": "^7.3.1",
    "@mui/material": "^7.3.1",
    "@types/lodash": "^4.17.20",
    "axios": "^1.12.0",
    "lodash": "^4.17.21",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-testing-library": "^6.4.0",
    "eslint-plugin-vitest": "^0.5.4",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.12",
    "vite-bundle-analyzer": "^0.18.0",
    "vitest": "^4.0.16"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  }
}
